# Cloudflare Tunnel Token
# Get this from: https://one.dash.cloudflare.com/ -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Admin password — gates the in-game admin panel (reset wins, set coins, issue notes).
# If unset, all admin endpoints are disabled. Pick something long & random.
ADMIN_PASSWORD=change-me-to-a-long-random-string
